{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ranse",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": false,
  "observability": { "enabled": true, "head_sampling_rate": 1 },

  // Empty-string `vars` are prompted by the Deploy-to-Cloudflare button UI.
  // Users fill these in during one-click install; we promote sensitive ones
  // to Worker secrets post-deploy via scripts/deploy.ts.
  "vars": {
    "APP_NAME": "Ranse",
    "LLM_DEFAULT_MODEL": "workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast"
  },

  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/setup/*", "/auth/*", "/agents/*", "/assets/*", "/healthz"]
  },

  "version_metadata": { "binding": "CF_VERSION" },

  "ai": { "binding": "AI" },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ranse-db",
      "database_id": "ranse-db",
      "migrations_dir": "migrations"
    }
  ],

  "r2_buckets": [
    { "binding": "BLOB", "bucket_name": "ranse-blob" }
  ],

  "kv_namespaces": [
    { "binding": "CACHE", "id": "ranse-cache" }
  ],

  "queues": {
    "producers": [
      { "binding": "ASYNC_JOBS", "queue": "ranse-jobs" },
      { "binding": "WEBHOOKS", "queue": "ranse-webhooks" }
    ],
    "consumers": [
      { "queue": "ranse-jobs", "max_batch_size": 10, "max_batch_timeout": 5 },
      { "queue": "ranse-webhooks", "max_batch_size": 10, "max_batch_timeout": 5 }
    ]
  },

  "durable_objects": {
    "bindings": [
      { "class_name": "WorkspaceSupervisorAgent", "name": "WorkspaceSupervisorAgent" },
      { "class_name": "MailboxAgent", "name": "MailboxAgent" },
      { "class_name": "UserSecretsStore", "name": "UserSecretsStore" }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkspaceSupervisorAgent", "MailboxAgent", "UserSecretsStore"]
    }
  ],

  "send_email": [{ "name": "EMAIL" }],

  "triggers": {
    "crons": ["*/5 * * * *"]
  },

  "unsafe": {
    "bindings": [
      {
        "name": "RATE_LIMIT_INGEST",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 100, "period": 60 }
      }
    ]
  }
}
